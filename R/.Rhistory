source("main/Statistical_tests.R")
source("main/secom.R")
source("main/rf_boruta.R")
cur.date <- format(Sys.Date(), "%y%m%d")
output_path <- (paste0("outputs/", cur.date, "/", cur.date))
output_path2 <- (paste0("outputs/", cur.date, "/"))
meta_data_path <- "/Users/gmark/Downloads/260105_AD_paper2_full_sample_metadata.xlsx"
set.seed(42)
cat_var <- c('ID', 'Sample_ID','AD_Status', 'sex', 'Time_point', 'race','cdr','apoe','apoe.dose','apoe.dose.mod','apoe4.carriage','DEP2YRS','CBSTROKE','Diabetes','Hypertension','HYPERCHO','CVHATT','THYROID','TOBAC30','ALCOHOL','INDEPEND','RESIDENC','cancer','APP','APPSEV','Tracer_used_for_classification','Tau_positivity','Tau_positivity_updated',	'Tau_marker','Amyloid_positivity', 'Enterotype_assignment', 'amyloid_tau_status')
num_var <- c("age","EDUC","BMI",'adi_natrank2019','mrfei',"combined.centiloid",'Tauopathy','LUMIPULSE_CSF_pTau','LUMIPULSE_CSF_tTau','ab42_ab40_ratio','Abeta4240_Plasma_IPMS','LPS_EIA_units','Days_sincePETpib','Days_sincePETav45','Days_sincePETtau','Days_since_biomarker_assessment', 'mr_vol_tot_wmhypointensities',	'LOAD_CorticalSignature_Thickness',	'mr_vol_r_hippocampus',	'mr_vol_l_hippocampus',	'mr_vol_tot_intracranial', 'hippocampus_vol_div_icv','PRS_p_0_00000005', 'MTG_seq_depth_final',	'MTG_seq_depth_final_M', "Calories_kcal", "Calories_from_fat_kcal", "Calories_from_SatFat_kcal", "Protein_g", "Carbohydrates_g", "Total_dietary_fiber_g", "Total_soluble_fiber_g", "Dietary_fiber_US_2016_g", "Soluble_fiber_US_2016", "Total_sugars_g", "Added_sugar_g","pT217_conc","CSF_sTREM2","CSF_YKL40","plasma_ptau217_C2N","Plasma_GFAP","Days_since_csf_PT217_conc","log2_NGAL", "log2_Calp", "log2_stool_YKL40")
fixed_effects_var <- c("age", "sex", "race", "BMI", "DEP2YRS", "DIABETES","HYPERTEN", "CVHATT", "INDEPEND","Days_since_biomarker_assessment","adi_natrank2019","mrfei","AD_Status")
reference_var=c("sex,M","race,White","APOE4.carriage,0","DEP2YRS,0","DIABETES,0","HYPERTEN,0","CVHATT,0","INDEPEND,1","AD_Status,healthy")
# Custom colors for plotting
custom_colors_hp <- c("Healthy" = "#49b9a5", "Preclinical" = "#eebe61")
custom_colors_AD <- c("healthy" = "#49b9a5", "preclinical" = "#eebe61", "symptomatic" = "#a98ec2")
custom_colors_amyloid_pos <- c("Negative" = "#49b9a5","Positive" = "#e193ad")
custom_colors_bw_wi_comp <- c("Between participant" = "#686f84", "Within participant" = "#B47E83")
## Metaphlan3 tree used in Aura's paper ###
m3.tree.Jan19 <- ape::read.tree(paste0(getwd(),"/datasets/tree_files/mpa_v30_CHOCOPhlAn_201901_species_tree.nwk.txt"))
m3.tree.Jan19$tip.label <- gsub('GCA_[0-9]+\\|', '', m3.tree.Jan19$tip.label)
## N=465 and 106 taxa
ps_m3_MTG <- make_phyloseq_object("datasets/metaphlan_files/240109_AD_metaphlan3_merged_n465_v1.txt",
path_to_metadata= meta_data_path,
tree_object = m3.tree.Jan19,
cat_vars=cat_var,
num_vars=num_var,
abund_threshold = 0.1) ## Latest metaphlan file before this update was 241022_AD_metaphlan3_merged_n465_v2.txt
## Subset Metaphlan3 phyloseq objects ##
### N=408 and 106 taxa
ps_mtg_long <- ps_m3_MTG %>%
subset_samples(MTG_seq_depth_final_M > 10) %>%
subset_samples(Stability_group == "Stable") %>%
subset_samples(AD_Status != "other")
## N=447; 18 samples were dropped because of depth lower than 10M
ps_m3_mtg_depth_filt_only <- ps_m3_MTG %>%
subset_samples(MTG_seq_depth_final_M > 10)
## N=234 samples
all_samples_closest_biomarker_df <- subset_sample_closest_to_biomarker_measure(ps_m3_MTG)
samples_closest_to_biomarker <- as.vector(all_samples_closest_biomarker_df$Sample_ID)
ps_m3_mtg_single_tp <- phyloseq::subset_samples(ps_m3_MTG, phyloseq::sample_names(ps_m3_MTG) %in% samples_closest_to_biomarker)
ps_mtg_single_tp.filt <- ps_m3_mtg_single_tp %>%
subset_samples(AD_Status != "Other") %>%
subset_samples(Stability_group == "Stable") %>%
subset_samples(MTG_seq_depth_final_M > 10)
ps_cs_hp <- ps_mtg_single_tp.filt %>% ps_filter(AD_Status == "Healthy" | AD_Status == "Preclinical")
train_indices <- sample(1:198, size = 0.6 * 198)
meta <- sample_data(ps_cs_hp) %>% as.data.frame()
meta$set <- "test"
meta$set[train_indices] <- "train"
library(scales)
meta$scaled_centiloid <- scales::rescale(meta$combined.centiloid, to = c(0, 100))
sample_data(ps_cs_hp) <- sample_data(meta)
#write.csv(as(sample_data(ps_cs_hp), "data.frame") , file=paste0(output_path, "_train_test_metadata.csv"), row.names = FALSE)
ps_cs_hp_train <- ps_cs_hp %>% ps_filter(set=="train")
library(lme4)
library(lmerTest)
long_guild_metadata <- long_guild_metadata %>%
mutate(Stool_Date_Collected = as.Date(Stool_Date_Collected)) %>%
group_by(ID) %>%
mutate(
baseline_date = min(Stool_Date_Collected),
time_from_baseline_mo = round(time_length(difftime(Stool_Date_Collected, baseline_date),"months"),2)
) %>%
ungroup()
long_guild_metadata <- read.csv("~/Documents/GitHub/PreclinicalAD_GutMicrobiome-Inflammation/R/Data/full_guild_metadata.csv")
long_guild_metadata <- long_guild_metadata %>%
mutate(Stool_Date_Collected = as.Date(Stool_Date_Collected)) %>%
group_by(ID) %>%
mutate(
baseline_date = min(Stool_Date_Collected),
time_from_baseline_mo = round(time_length(difftime(Stool_Date_Collected, baseline_date),"months"),2)
) %>%
ungroup()
long_guild_metadata <- long_guild_metadata %>%
group_by(ID) %>%
mutate(
baseline_date = min(Time_point),
time_from_baseline_mo = round(time_length(difftime(Time_point, baseline_date),"months"),2)
) %>%
ungroup()
long_guild_meta_filt <- long_guild_metadata %>% filter(Sample_ID %in% stability_cohort$Sample_ID)
options(na.action='na.fail')
columns_to_check <- c("guild_abundance", "AD_Status", "sex", "age", "BMI", "Diabetes", "Hypertension", "apoe4.carriage", "time_from_baseline_mo")
long_guild_metadata <- long_guild_metadata %>%
group_by(ID) %>%
mutate(
baseline_date = min(Time_diff_from_baseline_mo),
time_from_baseline_mo = round(time_length(difftime(Time_diff_from_baseline_mo, baseline_date),"months"),2)
) %>%
ungroup()
long_guild_meta_filt <- long_guild_metadata %>% filter(Sample_ID %in% stability_cohort$Sample_ID)
stability_cohort <- read_excel("/Users/gmark/Downloads/250718_longitudinal_stability_cohort_meta.xlsx")
long_guild_meta_filt <- long_guild_metadata %>% filter(Sample_ID %in% stability_cohort$Sample_ID)
options(na.action='na.fail')
columns_to_check <- c("guild_abundance", "AD_Status", "sex", "age", "BMI", "Diabetes", "Hypertension", "apoe4.carriage", "time_from_baseline_mo")
long_guild_meta_filt <- long_guild_meta_filt %>%
filter(if_all(all_of(columns_to_check), ~ !is.na(.)))
model <- lmer(guild_abundance ~ AD_Status+ sex + age + BMI+ Diabetes+ Hypertension + apoe4.carriage+ time_from_baseline_mo + (1|ID), data = long_guild_meta_filt)
options(na.action='na.fail')
columns_to_check <- c("guild_abundance", "AD_Status", "Sex", "Age", "BMI", "Diabetes", "Hypertension", "apoe4.carriage", "Time_diff_from_baseline_mo")
