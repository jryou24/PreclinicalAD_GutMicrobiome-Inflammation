ps_mtg_single_tp_test <- ps_mtg_single_tp %>% ps_filter(set=="test")  %>% sample_data() %>% data.frame()
lm0_last_guild <- lm(combined.centiloid ~ guild_abundance + AD_Status, data = ps_mtg_single_tp_test)
last_guild_anova_summary <- tidy(anova(lm0_last_guild, lm_last_guild_interaction))
